{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[svelte]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[proto3]": {
    "editor.defaultFormatter": "zxh404.vscode-proto3"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "prettier.configPath": "./.prettierrc.yml",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "files.exclude": {
    "**/node_modules": false,
    "**/.flatpak-builder": true,
    "**/target": true
  },
  "eslint.validate": ["html", "svelte", "typescript", "javascript"],
  "eslint.workingDirectories": [
    {"pattern": "./apps/*/", "!cwd": false},
    {"pattern": "./packages/*/", "!cwd": false}
  ],
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "rewrap.wrappingColumn": 100,
  "typescript.tsdk": "node_modules/typescript/lib",
  "rust-analyzer.linkedProjects": [
    "apps/desktop/src/rust/common/Cargo.toml",
    "apps/desktop/src/rust/helper/Cargo.toml",
    "apps/desktop/src/rust/launcher/Cargo.toml"
  ],
  "rust-analyzer.runnables.extraEnv": {
    "THREEMA_BUILD_FLAVOR": "consumer-sandbox"
  },
  "rust-analyzer.server.extraEnv": {
    "THREEMA_BUILD_FLAVOR": "consumer-sandbox"
  },
  "json.schemaDownload.trustedDomains": {
    "https://turborepo.com/schema.json": true
  }
}
