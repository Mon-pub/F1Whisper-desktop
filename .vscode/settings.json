{
  "[svelte]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[proto3]": {
    "editor.defaultFormatter": "zxh404.vscode-proto3"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "eslint.validate": ["html", "svelte", "typescript", "javascript"],
  "eslint.workingDirectories": [
    {"pattern": "./apps/*/", "!cwd": false},
    {"pattern": "./packages/*/", "!cwd": false}
  ],
  "files.associations": {
    "**/apps/conferencing/**/*.css": "tailwindcss",
    "**/packages/ui/**/*.css": "tailwindcss"
  },
  "files.exclude": {
    "**/node_modules": false,
    "**/.flatpak-builder": true,
    "**/target": true
  },
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.tsserver.experimental.enableProjectDiagnostics": false,
  "json.schemaDownload.trustedDomains": {
    "https://*.turborepo.dev": true
  },
  "prettier.configPath": "./.prettierrc.yml",
  "rewrap.wrappingColumn": 100,
  "rust-analyzer.linkedProjects": [
    "apps/desktop/src/rust/common/Cargo.toml",
    "apps/desktop/src/rust/helper/Cargo.toml",
    "apps/desktop/src/rust/launcher/Cargo.toml"
  ],
  "rust-analyzer.runnables.extraEnv": {
    "THREEMA_BUILD_FLAVOR": "consumer-sandbox"
  },
  "rust-analyzer.server.extraEnv": {
    "THREEMA_BUILD_FLAVOR": "consumer-sandbox"
  },
  "tailwindCSS.classFunctions": ["tv"],
  "tailwindCSS.experimental.configFile": {
    "apps/conferencing/src/app.css": ["apps/conferencing/src/**"],
    "packages/ui/src/theme.css": ["packages/ui/src/**"]
  },
  "tailwindCSS.validate": true
}
