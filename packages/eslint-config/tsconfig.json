{
  "$schema": "https://www.schemastore.org/tsconfig",
  "extends": "@threema/ts-config/tsconfig.node22.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    // We're not actually compiling TypeScript in this package, and only use its type-checking
    // capabilities.
    "noEmit": true
  },
  "include": ["src/**.js"]
}
