{
  "name": "@threema/ts-utils",
  "description": "A collection of sugar and utilities for TypeScript",
  "author": "Threema GmbH",
  "license": "AGPL-3.0+",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:tsc": "tsc --noEmit"
  },
  "devDependencies": {
    "@threema/eslint-config": "workspace:*",
    "@threema/ts-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
