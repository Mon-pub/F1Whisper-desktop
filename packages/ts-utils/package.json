{
  "name": "@threema/ts-utils",
  "description": "A collection of sugar and utilities for TypeScript",
  "author": "Threema GmbH",
  "license": "AGPL-3.0+",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./build/*.d.ts",
      "import": "./build/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./build/*"
      ]
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean:build": "rm -rf build",
    "dev": "tsc --incremental --watch",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:tsc": "tsc --noEmit"
  },
  "devDependencies": {
    "@threema/eslint-config": "workspace:*",
    "@threema/ts-config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
