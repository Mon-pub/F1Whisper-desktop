{
  "name": "@threema/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/theme.css"
  },
  "scripts": {
    "build:storybook": "storybook build -o ./storybook-static",
    "dev:storybook": "storybook dev --ci -p 6006",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "lint:tsc": "svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "test:vitest": "vitest run --coverage"
  },
  "dependencies": {
    "@threema/branding": "workspace:*",
    "@threema/dom": "workspace:*",
    "@threema/ts-utils": "workspace:*",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:"
  },
  "devDependencies": {
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-svelte-csf": "catalog:",
    "@storybook/svelte-vite": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@threema/eslint-config": "workspace:*",
    "@threema/ts-config": "workspace:*",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-storybook": "catalog:",
    "eslint-plugin-svelte": "catalog:",
    "globals": "catalog:",
    "storybook": "catalog:",
    "svelte-check": "catalog:",
    "svelte-eslint-parser": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-svelte": "catalog:"
  },
  "peerDependencies": {
    "svelte": "catalog:"
  }
}
