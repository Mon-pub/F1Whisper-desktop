{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "rebuild:dependencies": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "rebuild:electron": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "build": {
      "cache": false,
      "dependsOn": ["rebuild:electron"],
      "env": ["CUSTOM_CONFIG_*"],
      "outputs": [
        "packaging/build/**",
        "packaging/flatpak/build/**",
        "packaging/flatpak/repo/**",
        "packaging/flatpak/ch.threema.*-desktop.yml",
        "packaging/flatpak/generated-sources.json",
        "packaging/flatpak/.flatpak-builder/**"
      ]
    },
    "build:cli": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["build/cli/cli/bin.cjs"]
    },
    "clean:build": {
      "dependsOn": ["clean:build:flatpak"]
    },
    "clean:build:flatpak": {
      "cache": false
    },
    "coverage": {
      "dependsOn": ["coverage:karma", "coverage:mocha"]
    },
    "coverage:karma": {
      "dependsOn": ["test:karma"]
    },
    "coverage:mocha": {
      "dependsOn": ["rebuild:dependencies"],
      "outputs": [".nyc_output_mocha/**"]
    },
    "dist": {
      "cache": false,
      "env": ["CUSTOM_CONFIG_*"]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["rebuild:electron"]
    },
    "dev:cli": {
      "dependsOn": ["build:cli"],
      "persistent": true
    },
    "generate:icons": {
      "dependsOn": [
        "generate:icons:flatpak",
        "generate:icons:macos",
        "generate:icons:web",
        "generate:icons:windows"
      ]
    },
    "generate:icons:flatpak": {
      "cache": false
    },
    "generate:icons:macos": {
      "cache": false
    },
    "generate:icons:macos:custom": {
      "cache": false
    },
    "generate:icons:web": {
      "cache": false
    },
    "generate:icons:web:custom": {
      "cache": false
    },
    "generate:icons:windows": {
      "cache": false
    },
    "generate:icons:windows:custom": {
      "cache": false
    },
    "generate:protobuf": {
      "cache": false
    },
    "generate:safe-enums": {
      "cache": false
    },
    "generate:structbuf": {
      "cache": false
    },
    "generate:translations": {
      "outputs": ["src/translations/**"]
    },
    "package": {
      "env": ["CUSTOM_CONFIG_*"]
    },
    "test:karma": {
      "dependsOn": ["rebuild:dependencies"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".nyc_output_karma/**"]
    },
    "test:mocha": {
      "dependsOn": ["rebuild:dependencies"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "test:playwright": {
      "dependsOn": ["dist"],
      "inputs": ["$TURBO_DEFAULT$"]
    }
  }
}
