# Temporary
/.temp/

# Build directories
/build/
/export/

# Electron
/electron.pid

# Testing & code coverage
/.nyc_output_karma/
/.nyc_output_mocha/
/coverage/
/junit/

# Unused translation keys
src/translations/**/*_old.json

# Playwright
/build/playwright/test-results
/playwright-report/
/blob-report/
/playwright/.cache/
src/test/playwright/test-data-*.local.json
src/test/playwright/test-data-*-live.json

# Custom build config (private: contains the deployer's OnPrem server URL).
# Build with CUSTOM_CONFIG_PATH pointing at your own copy; see config/f1whisper-custom-config.example.json.
config/f1whisper-custom-config.json
# Belt: any local override config sibling stays private (the tracked *.example.json is unaffected).
config/*.local.json

# Custom assets
packaging/assets/icons/**/custom-onprem.*
packaging/assets/installers/custom*
src/public/res/**/custom-onprem/
