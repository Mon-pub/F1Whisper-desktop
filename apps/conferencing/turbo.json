{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test:playwright": {
      "dependsOn": ["build"],
      "env": ["GITLAB_CI"],
      "inputs": ["$TURBO_DEFAULT$"]
    }
  }
}
