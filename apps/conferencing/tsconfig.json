{
  "extends": "@threema/ts-config/tsconfig.dom.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["svelte"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": [
    "playwright.config.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "src/**/*.ts",
    "src/**/*.svelte"
  ]
}
