{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["DEBUG", "TURBO_*", "PW_*"],
  "tasks": {
    "//#lint:prettier": {},
    "//#lint:prettier:fix": {},
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "dev": {
      "dependsOn": ["rebuild:electron"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "dist": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint": {
      "dependsOn": [
        "//#lint:prettier",
        "^lint:eslint",
        "lint:eslint",
        "^lint:svelte",
        "lint:svelte",
        "^lint:tsc",
        "lint:tsc"
      ]
    },
    "lint:eslint": {
      "dependsOn": ["^build", "^lint:eslint"]
    },
    "lint:eslint:fix": {
      "dependsOn": ["^build", "^lint:eslint:fix"]
    },
    "lint:fix": {
      "dependsOn": ["//#lint:prettier:fix", "^lint:eslint:fix", "lint:eslint:fix"]
    },
    "lint:svelte": {
      "dependsOn": ["^build", "^lint:svelte"]
    },
    "lint:tsc": {
      "dependsOn": ["^build", "^lint:tsc"]
    },
    "test:playwright": {
      "dependsOn": ["dist"],
      "inputs": ["$TURBO_DEFAULT$"]
    }
  },
  "ui": "tui"
}
