{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["TURBO_*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:eslint": {
      "dependsOn": ["^build", "^lint:eslint"]
    },
    "lint:svelte": {
      "dependsOn": ["^build", "^lint:svelte"]
    },
    "lint:tsc": {
      "dependsOn": ["^build", "^lint:tsc"]
    }
  },
  "ui": "tui"
}
