{
  "name": "threema-desktop-monorepo",
  "description": "Use Threema on your Desktop",
  "author": "Threema GmbH",
  "license": "AGPL-3.0+",
  "homepage": "https://threema.ch/",
  "keywords": [
    "threema",
    "messenger",
    "communication"
  ],
  "private": true,
  "scripts": {
    "build:desktop:cli": "turbo run build:cli --filter=threema-desktop",
    "build:desktop:consumer-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=consumer turbo run build --filter=threema-desktop",
    "build:desktop:consumer-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=consumer turbo run build --filter=threema-desktop",
    "build:desktop:custom-onprem": "TURBO_BUILD_ENVIRONMENT=onprem TURBO_BUILD_VARIANT=custom turbo run build --filter=threema-desktop",
    "build:desktop:work-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=work turbo run build --filter=threema-desktop",
    "build:desktop:work-onprem": "TURBO_BUILD_ENVIRONMENT=onprem TURBO_BUILD_VARIANT=work turbo run build --filter=threema-desktop",
    "build:desktop:work-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=work turbo run build --filter=threema-desktop",
    "build:packages": "turbo run build --filter=\"./packages/*\"",
    "clean": "git clean -d -x -f",
    "clean:build": "turbo run clean:build",
    "clean:node_modules": "turbo run clean:node_modules",
    "coverage": "turbo run coverage",
    "dev:desktop:cli": "turbo run dev:cli --filter=threema-desktop",
    "dev:desktop:consumer-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=consumer turbo run dev --filter=threema-desktop",
    "dev:desktop:consumer-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=consumer turbo run dev --filter=threema-desktop",
    "dev:desktop:work-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=work turbo run dev --filter=threema-desktop",
    "dev:desktop:work-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=work turbo run dev --filter=threema-desktop",
    "dev:desktop:work-onprem": "TURBO_BUILD_ENVIRONMENT=onprem TURBO_BUILD_VARIANT=work turbo run dev --filter=threema-desktop",
    "dist:desktop:consumer-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=consumer turbo run dist --filter=threema-desktop",
    "dist:desktop:consumer-live-testing": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=consumer TURBO_BUILD_MODE=testing turbo run dist --filter=threema-desktop",
    "dist:desktop:consumer-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=consumer turbo run dist --filter=threema-desktop",
    "dist:desktop:consumer-sandbox-testing": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=consumer TURBO_BUILD_MODE=testing turbo run dist --filter=threema-desktop",
    "dist:desktop:custom-onprem": "TURBO_BUILD_ENVIRONMENT=onprem TURBO_BUILD_VARIANT=custom turbo run dist --filter=threema-desktop",
    "dist:desktop:work-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=work turbo run dist --filter=threema-desktop",
    "dist:desktop:work-live-testing": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=work TURBO_BUILD_MODE=testing turbo run dist --filter=threema-desktop",
    "dist:desktop:work-onprem": "TURBO_BUILD_ENVIRONMENT=onprem TURBO_BUILD_VARIANT=work turbo run dist --filter=threema-desktop",
    "dist:desktop:work-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=work turbo run dist --filter=threema-desktop",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:eslint": "turbo run lint:eslint",
    "lint:eslint:fix": "turbo run lint:eslint:fix",
    "lint:prettier": "prettier -c \"**/*.{css,html,js,json,md,scss,svelte,ts,xml,yml}\"",
    "lint:prettier:fix": "prettier --write \"**/*.{css,html,js,json,md,scss,svelte,ts,xml,yml}\"",
    "lint:svelte": "turbo run lint:svelte",
    "lint:tsc": "turbo run lint:tsc",
    "package:desktop:consumer-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=consumer turbo run package --filter=threema-desktop",
    "package:desktop:consumer-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=consumer turbo run package --filter=threema-desktop",
    "package:desktop:custom-onprem": "TURBO_BUILD_ENVIRONMENT=onprem TURBO_BUILD_VARIANT=custom turbo run package --filter=threema-desktop",
    "package:desktop:work-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=work turbo run package --filter=threema-desktop",
    "package:desktop:work-onprem": "TURBO_BUILD_ENVIRONMENT=onprem TURBO_BUILD_VARIANT=work turbo run package --filter=threema-desktop",
    "package:desktop:work-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=work turbo run package --filter=threema-desktop",
    "test:desktop:karma": "turbo run test:karma --filter=threema-desktop",
    "test:desktop:mocha": "turbo run test:mocha --filter=threema-desktop",
    "test:desktop:playwright:consumer-sandbox": "TURBO_BUILD_ENVIRONMENT=sandbox TURBO_BUILD_VARIANT=consumer TURBO_BUILD_MODE=testing PW_PROFILE=playwright turbo run test:playwright --filter=threema-desktop",
    "test:desktop:playwright:screenshots:consumer-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=consumer TURBO_BUILD_MODE=testing PW_PROFILE=playwright PW_SCREENSHOTS=true turbo run test:playwright --filter=threema-desktop",
    "test:desktop:playwright:screenshots:work-live": "TURBO_BUILD_ENVIRONMENT=live TURBO_BUILD_VARIANT=work TURBO_BUILD_MODE=testing PW_PROFILE=playwright PW_SCREENSHOTS=true turbo run test:playwright --filter=threema-desktop",
    "update:libthreema": "turbo run update --filter=@threema/libthreema-wasm"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-svelte": "catalog:",
    "turbo": "2.6.1",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": "22.17.0"
  }
}
